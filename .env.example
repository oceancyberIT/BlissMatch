# Core app configuration
NODE_ENV=development

# Web (Next.js)
WEB_PORT=4001
NEXT_PUBLIC_API_URL=http://localhost:4000

# API (NestJS)
API_PORT=4000

# PostgreSQL
POSTGRES_USER=blissmatch
POSTGRES_PASSWORD=blissmatch_password
POSTGRES_DB=blissmatch
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# JWT / auth placeholders (to be refined per project)
JWT_SECRET=change_me_in_real_env
JWT_EXPIRES_IN=15m

# Admin credentials (used for /auth/admin/login)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_this_admin_password

# Web origin allowed for CORS (NestJS API)
WEB_ORIGIN=http://localhost:4001

# SMTP (optional, required for enquiry confirmation emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=change_this_mail_password
MAIL_FROM="BlissMatch <no-reply@blissmatch.com>"

